# TrackVolt local environment example
# Copy this file to `.env.local` for local client-side development.
# Keep real secrets in `.env.local` only. Do not commit filled values.

# Optional: Firebase web config for Cloud Sync.
# If left blank, the app can still be configured at runtime from Settings > Cloud Sync.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: USDA FoodData Central API key for the serverless nutrition search endpoint.
# Used by `api/nutrition-search.ts`.
# For deployed use, set this in Vercel project environment variables.
USDA_API_KEY=
